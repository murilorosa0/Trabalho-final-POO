<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ui.TaxesScreen">
  <grid id="27dc6" binding="taxesPanel" layout-manager="GridLayoutManager" row-count="4" column-count="2" same-size-horizontally="true" same-size-vertically="false" hgap="15" vgap="12">
    <margin top="20" left="25" bottom="20" right="25"/>
    <constraints>
      <xy x="20" y="20" width="500" height="300"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <!-- Título Selecione um Estado (Coluna 0, Linha 0) -->
      <component id="df1b9" class="javax.swing.JLabel" binding="textArea">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="SELECIONE UM ESTADO"/>
        </properties>
      </component>
      
      <!-- Título Valor da Alíquota (Coluna 1, Linha 0) -->
      <component id="72aad" class="javax.swing.JLabel" binding="textArea1">
        <constraints>
          <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="VALOR DA ALÍQUOTA"/>
        </properties>
      </component>
      
      <!-- JComboBox de Estados (Coluna 0, Linha 1) -->
      <component id="e4065" class="javax.swing.JComboBox" binding="statesList">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <model/>
        </properties>
      </component>
      
      <!-- JFormattedTextField da Alíquota (Coluna 1, Linha 1) -->
      <component id="4f8c6" class="javax.swing.JFormattedTextField" binding="taxValue">
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
            <preferred-size width="150" height="-1"/>
          </grid>
        </constraints>
        <properties/>
      </component>
      
      <!-- Botão VER ALÍQUOTAS (Coluna 0, Linha 2) -->
      <component id="f2a28" class="javax.swing.JButton" binding="viewButton">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false">
            <preferred-size width="150" height="-1"/>
          </grid>
        </constraints>
        <properties>
          <text value="VER ALÍQUOTAS"/>
        </properties>
      </component>
      
      <!-- Botão APLICAR (Coluna 1, Linha 2) -->
      <component id="d414d" class="javax.swing.JButton" binding="doneButton">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false">
            <preferred-size width="150" height="-1"/>
          </grid>
        </constraints>
        <properties>
          <text value="APLICAR"/>
        </properties>
      </component>
      
      <!-- Mola que empurra tudo para cima de forma limpa (Linha 3) -->
      <vspacer id="8d09">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
      </vspacer>
    </children>
  </grid>
</form>
